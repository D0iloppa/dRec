# =====================================================================
# dRec — Environment Variables (Template)
# ---------------------------------------------------------------------
# 본 파일은 git 에 커밋된다. 실제 값은 `.env` 에 작성하며 절대 노출 금지.
# `.env` 와 `.env.example` 은 항상 동일한 키셋을 유지한다.
# =====================================================================

# ── Database (공유 Postgres devdb 의 전용 database `drec`) ────────────
# 베이스 dev 스택의 DB_PASSWORD 와 동일 값을 채운다.
DB_PASSWORD=<change-me>

# ── 1단계: 로컬 Whisper (STT) ────────────────────────────────────────
# 모델: tiny|base|small|medium|large-v3 (클수록 정확·느림). 한국어는 small 이상 권장.
DREC_WHISPER_MODEL=small
DREC_WHISPER_DEVICE=cpu        # GPU 가 있으면 cuda
DREC_WHISPER_COMPUTE=int8      # cuda 면 float16 권장

# ── 2단계: Claude 회의록 (claude CLI / Claude Code) ──────────────────
DREC_CLAUDE_MODEL=claude-opus-4-8
# claude CLI OAuth 토큰. 호스트에서 `claude setup-token` 으로 발급해 채운다.
CLAUDE_CODE_OAUTH_TOKEN=<change-me>
