# Legacy lsh services
lsh_*/

# Database
postgres_lsh/

# SQL dumps
*.sql

# DKIM keys (secrets)
postfix/dkim-keys/*.private

# Node modules
**/node_modules/

# React build output
doil-react/dist/

# Logs
**/logs/
*.log

# PID files
**/.dev-server.pid

# SSL certs (managed separately)
nginx/live/

# CDN assets
nginx/cdn/
cdn_storage/
imgproxy/

# Nginx built output
nginx/html/assets/
nginx/html/index.html

# Jellyfin (data & cache)
jellyfin/

# Kavita (separate repo)
Kavita/

# doil-sb (separate repo)
doil-sb/

# OpenProject (Docker volumes, no local dir needed)
openproject_data/
openproject_pgdata/

# Env files
**/.env
**/.env.local

# Agent 발행 산출물 / 상태 / 브라우저 프로필 / node_modules
agent/*/output/
agent/*/state/
agent/*/profile/
agent/*/node_modules/

# CouchDB local.ini — 런타임에 admin 해시/uuid 가 기록됨 (비밀)
couchdb/local.ini

# 파이썬 캐시 / playwright 세션 로그
__pycache__/
agent/*/.playwright-mcp/
