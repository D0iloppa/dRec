# DoilTimes 설정 — 복사해서 .env 로 (gitignore 됨)

# 수신자 (필수). 여러 명은 ; 또는 , 로 구분
RECIPIENTS=you@example.com;other@example.com

# From 헤더 — 수신자가 보는 발신 주소 (기본 agent@doil.me)
#SMTP_FROM=DoilTimes <agent@doil.me>

# SMTP 인증 — 미지정 시 레포 루트 .env 의 POSTFIX_SASL_USERS 첫 항목(ohno@doil.me)을 사용
#SMTP_HOST=localhost
#SMTP_PORT=587
#SMTP_USER=ohno@doil.me
#SMTP_PASS=secret

# Google AdSense — 둘 다 있어야 페이지 최하단에 광고 유닛이 렌더됨 (메일엔 광고 미삽입)
# CLIENT = 퍼블리셔 ID(ca-pub-...), SLOT = 콘솔에서 만든 디스플레이 광고 유닛의 data-ad-slot 숫자
ADSENSE_CLIENT=ca-pub-xxxxxxxxxxxxxxxx
#ADSENSE_SLOT=1234567890
