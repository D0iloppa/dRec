# SourcingSearcher 설정 — 복사해서 .env 로 (gitignore 됨)

# 보고서 수신자 (필수). 여러 명은 ; 또는 , 로 구분
RECIPIENTS=you@example.com

# 개발자 프로필 — "적합도" 판단 기준. 구체적일수록 선별 정확도가 오른다
PROFILE=웹개발, 소프트웨어, 업무 자동화/매크로, AI 연계 전반

# 탐색 대상 사이트 — "이름|URL" 을 ; 로 구분
SITES=위시켓|https://www.wishket.com/project/;OKKY 구인구직|https://okky.kr/recruit

# 선택
#MODEL=sonnet                       # 발굴 모델 (기본 sonnet). opus 로 올리면 판단력↑ 비용↑
#LEAD_MAX_AGE_DAYS=14               # 게시일이 이보다 오래된 의뢰글은 배제 (기본 14일)
#SMTP_FROM=SourcingSearcher <agent@doil.me>
#SMTP_HOST=localhost
#SMTP_PORT=587
#SMTP_USER=ohno@doil.me             # 미지정 시 루트 .env 의 POSTFIX_SASL_USERS 사용
#SMTP_PASS=secret
